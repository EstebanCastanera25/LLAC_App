# === Requerida (bootstrap) ===
# Backend (sin /api ni barra final). La app le pide su config a este backend.
VITE_API_BASE=

# === Opcionales (FALLBACK) ===
# La config real se administra desde el panel (APP → Configuración) y la app la
# lee al arrancar vía GET /api/app/config. Estas VITE_* solo se usan como
# respaldo si el backend no responde en el primer arranque (no hay cache aún).
# VITE_AUTH0_DOMAIN=tu-tenant.us.auth0.com
# VITE_AUTH0_CLIENT_ID=
# VITE_AUTH0_CALLBACK=
# VITE_DEFAULT_COMUNA_ID=
# VITE_FISCALIZACION_ENABLED=false
